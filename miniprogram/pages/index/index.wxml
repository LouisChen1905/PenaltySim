<view class="page">
  <view class="stage">
    <canvas
      id="simCanvas"
      type="2d"
      class="sim-canvas"
      bindtouchstart="onCanvasTouch"
      bindtouchmove="onCanvasTouch"
    ></canvas>
    <view class="scoreboard">
      <text class="status">{{status}}</text>
      <text class="score">进球 {{goals}} / 射门 {{shots}}</text>
    </view>
  </view>

  <view class="panel">
    <view class="header">
      <text class="title">点球模拟器</text>
      <text class="subtitle">小程序 Canvas 版，保留 3D 坐标物理、弧线和门将扑救。</text>
    </view>

    <view class="control">
      <text>方向</text>
      <slider min="-100" max="100" value="{{aim}}" activeColor="#f4c75c" backgroundColor="#405346" bindchange="onAim" bindchanging="onAim" />
      <text class="value">{{aim}}</text>
    </view>

    <view class="control">
      <text>高度</text>
      <slider min="0" max="100" value="{{height}}" activeColor="#f4c75c" backgroundColor="#405346" bindchange="onHeight" bindchanging="onHeight" />
      <text class="value">{{height}}</text>
    </view>

    <view class="control">
      <text>力度</text>
      <slider min="48" max="100" value="{{power}}" activeColor="#f4c75c" backgroundColor="#405346" bindchange="onPower" bindchanging="onPower" />
      <text class="value">{{power}}%</text>
    </view>

    <view class="control">
      <text>弧线</text>
      <slider min="-60" max="60" value="{{curl}}" activeColor="#f4c75c" backgroundColor="#405346" bindchange="onCurl" bindchanging="onCurl" />
      <text class="value">{{curl}}</text>
    </view>

    <view class="actions">
      <button class="shoot" bindtap="shoot">射门</button>
      <button class="reset" bindtap="reset">重置</button>
    </view>

    <view class="readout">
      <view><text>球速</text><text>{{speedText}}</text></view>
      <view><text>落点</text><text>{{targetText}}</text></view>
      <view><text>门将</text><text>{{keeperText}}</text></view>
    </view>
  </view>
</view>
